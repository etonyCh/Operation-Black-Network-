{
  "name": "black-network",
  "version": "0.1.0",
  "description": "Network penetration testing & security audit desktop application",
  "main": "out/main/index.js",
  "homepage": "https://github.com/black-network/black-network",
  "author": "Tony Charmant <contact@tonycharmant.com>",
  "license": "MIT",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "package:deb": "npm run build && electron-builder --linux deb",
    "package:appimage": "npm run build && electron-builder --linux AppImage",
    "test": "vitest run",
    "test:e2e": "playwright test",
    "lint": "eslint . --ext .ts,.tsx --report-unused-disable-directives --max-warnings 0"
  },
  "dependencies": {
    "@electron-toolkit/preload": "^3.0.0",
    "@electron-toolkit/utils": "^3.0.0",
    "@google/generative-ai": "^0.15.0",
    "@tanstack/react-query": "^5.51.0",
    "better-sqlite3": "^11.1.1",
    "class-variance-authority": "^0.7.0",
    "clsx": "^2.1.0",
    "d3": "^7.9.0",
    "docx": "^8.5.0",
    "dotenv": "^17.4.2",
    "execa": "^9.3.0",
    "framer-motion": "^11.3.0",
    "keytar": "^7.9.0",
    "lucide-react": "^0.400.0",
    "p-queue": "^8.0.0",
    "pdfkit": "^0.15.0",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "recharts": "^2.12.0",
    "sudo-prompt": "^9.2.1",
    "tailwind-merge": "^2.4.0",
    "tailwindcss": "^3.4.0",
    "winston": "^3.14.0",
    "xml2js": "^0.6.0",
    "zustand": "^4.5.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.46.0",
    "@types/better-sqlite3": "^7.6.0",
    "@types/d3": "^7.4.0",
    "@types/node": "^22.0.0",
    "@types/pdfkit": "^0.13.0",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@types/xml2js": "^0.4.14",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "@vitejs/plugin-react": "^4.3.0",
    "autoprefixer": "^10.4.0",
    "electron": "^30.5.1",
    "electron-builder": "^25.0.0",
    "electron-vite": "^2.3.0",
    "eslint": "^9.7.0",
    "eslint-plugin-react-hooks": "^5.1.0",
    "postcss": "^8.4.0",
    "prettier": "^3.3.0",
    "typescript": "^5.5.0",
    "vite": "^5.4.0",
    "vitest": "^2.0.0"
  },
  "build": {
    "appId": "com.black-network.app",
    "productName": "Black Network",
    "directories": {
      "output": "dist"
    },
    "linux": {
      "target": [
        "deb",
        "AppImage"
      ],
      "category": "Network",
      "maintainer": "Tony Charmant <contact@tonycharmant.com>",
      "vendor": "Tony Charmant",
      "description": "Network penetration testing & security audit desktop application",
      "desktop": {
        "Name": "Black Network",
        "Comment": "Network penetration testing & security audit desktop application",
        "Type": "Application"
      }
    },
    "deb": {
      "depends": [
        "nmap",
        "tshark",
        "arp-scan"
      ]
    },
    "files": [
      "out/**/*",
      "resources/**/*"
    ],
    "extraResources": [
      {
        "from": "resources",
        "to": "resources"
      }
    ]
  }
}
