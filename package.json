{
  "name": "black-network",
  "version": "0.1.0",
  "description": "Network penetration testing & security auditing platform.",
  "main": "out/main/index.js",
  "homepage": "https://github.com/black-network/black-network",
  "author": "tonyCh <contact@tonycharmant.com>",
  "license": "FSS",
  "scripts": {
    "dev": "electron-vite dev -- --no-sandbox",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "package:deb": "npm run build && electron-builder --linux deb",
    "package:appimage": "npm run build && electron-builder --linux AppImage",
    "test": "vitest run",
    "test:e2e": "playwright test",
    "lint": "eslint . --ext .ts,.tsx --report-unused-disable-directives --max-warnings 0"
  },
  "dependencies": {
    "@electron-toolkit/preload": "^3.0.0",
    "@electron-toolkit/utils": "^3.0.0",
    "@google/generative-ai": "^0.15.0",
    "@tanstack/react-query": "^5.51.0",
    "better-sqlite3": "^11.1.1",
    "call-bind": "^1.0.9",
    "call-bind-apply-helpers": "^1.0.2",
    "class-variance-authority": "^0.7.0",
    "clsx": "^2.1.0",
    "d3": "^7.9.0",
    "docx": "^8.5.0",
    "dotenv": "^17.4.2",
    "dunder-proto": "^1.0.1",
    "execa": "^9.3.0",
    "framer-motion": "^11.3.0",
    "get-intrinsic": "^1.3.0",
    "keytar": "^7.9.0",
    "lucide-react": "^0.400.0",
    "multicast-dns": "^7.2.5",
    "node-ssdp": "^4.0.1",
    "object.assign": "^4.1.7",
    "p-queue": "^8.0.0",
    "pdfkit": "^0.15.0",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "recharts": "^2.12.0",
    "sudo-prompt": "^9.2.1",
    "tailwind-merge": "^2.4.0",
    "tailwindcss": "^3.4.0",
    "winston": "^3.14.0",
    "xml2js": "^0.6.0",
    "zustand": "^4.5.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.46.0",
    "@types/better-sqlite3": "^7.6.0",
    "@types/d3": "^7.4.0",
    "@types/multicast-dns": "^7.2.4",
    "@types/node": "^22.0.0",
    "@types/node-ssdp": "^4.0.5",
    "@types/pdfkit": "^0.13.0",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@types/xml2js": "^0.4.14",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "@vitejs/plugin-react": "^4.3.0",
    "autoprefixer": "^10.4.0",
    "electron": "^30.5.1",
    "electron-builder": "^25.0.0",
    "electron-vite": "^2.3.0",
    "eslint": "^9.7.0",
    "eslint-plugin-react-hooks": "^5.1.0",
    "postcss": "^8.4.0",
    "prettier": "^3.3.0",
    "typescript": "^5.5.0",
    "vite": "^5.4.0",
    "vitest": "^2.0.0"
  },
  "build": {
    "appId": "com.black-network.app",
    "productName": "Black Network",
    "directories": {
      "output": "dist"
    },
    "linux": {
      "target": [
        "deb",
        "AppImage"
      ],
      "category": "Network",
      "maintainer": "tonyCh <contact@tonycharmant.com>",
      "vendor": "tonyCh",
      "description": "Black Network is a state-of-the-art, comprehensive network penetration testing and security auditing platform. Designed for cybersecurity professionals, it integrates advanced traffic analysis, vulnerability scanning, and real-time network intelligence into an intuitive desktop environment.",
      "executableArgs": [
        "--no-sandbox"
      ],
      "desktop": {
        "Name": "Black Network",
        "Comment": "Advanced Network Penetration Testing & Security Audit Platform",
        "Type": "Application"
      }
    },
    "deb": {
      "depends": [
        "nmap",
        "tshark",
        "arp-scan"
      ]
    },
    "files": [
      "out/**/*",
      "resources/**/*"
    ],
    "extraResources": [
      {
        "from": "resources",
        "to": "resources"
      }
    ]
  }
}
